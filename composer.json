{
    "name": "sarouty/immobilier",
    "description": "Plateforme immobilière Sarouty - Laravel 11",
    "type": "project",
    "require": {
        "php": "^8.2",
        "cloudinary-labs/cloudinary-laravel": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "intervention/image": "^3.0",
        "laravel/breeze": "^2.0",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "mailgun/mailgun-php": "^4.0",
        "openai-php/laravel": "^0.10",
        "spatie/laravel-medialibrary": "^11.0",
        "stripe/stripe-php": "^16.0",
        "twilio/sdk": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
