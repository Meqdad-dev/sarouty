APP_NAME="Sarouty"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Base de données
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=darmaroc
DB_USERNAME=root
DB_PASSWORD=

# Cache & Queue (Redis pour Horizon)
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Emails : Mailgun ou Brevo ────────────────────────────────
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS="noreply@darmaroc.ma"
MAIL_FROM_NAME="DarMaroc"

# Mailgun
MAILGUN_DOMAIN=mg.darmaroc.ma
MAILGUN_SECRET=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_ENDPOINT=api.eu.mailgun.net

# Brevo (alternative à Mailgun)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@email.com
# MAIL_PASSWORD=votre-cle-brevo
# MAIL_ENCRYPTION=tls

# ─── SMS : Twilio ou Infobip ─────────────────────────────────
# Twilio
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+212XXXXXXXXX

# Infobip (alternative)
# INFOBIP_BASE_URL=https://XXXXX.api.infobip.com
# INFOBIP_API_KEY=xxxxxxxxxxxxxxxxxxxx
# INFOBIP_FROM=DarMaroc

# ─── OpenAI (IA) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
OPENAI_ORGANIZATION=org-xxxxxxxx

# ─── Cartes OpenStreetMap / Nominatim ────────────────────────
NOMINATIM_USER_AGENT="DarMaroc/1.0 (contact@darmaroc.ma)"

# ─── Paiements (Stripe ou CMI Maroc) ─────────────────────────
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxx

# ─── Laravel Horizon ──────────────────────────────────────────
HORIZON_PREFIX=darmaroc_horizon

# ─── Stockage ─────────────────────────────────────────────────
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=darmaroc-uploads
